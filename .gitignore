# =====================================================
# Build outputs (Gradle + IntelliJ Plugin)
# =====================================================
/build/
/out/
/release/
/dist/

# Per-module build dirs (some multi-module layouts use these)
/*/build/
/*/out/

# =====================================================
# IDE — IntelliJ IDEA + Android Studio
# =====================================================
.idea/
*.iml
*.iws
*.ipr
*.iéb
.vscode/

# Android Studio specific
/.idea/caches/
/.idea/libraries/
/.idea/modules.xml
/.idea/workspace.xml
/.idea/navEditor.xml
/.idea/assetWizardSettings.xml
/.idea/dictionaries
/.idea/caches_build_file
/.idea/shelf
/.idea/tasks.xml
/.idea/usage.statistics.xml
/.idea/dictionaries/
captures/

# =====================================================
# Gradle
# =====================================================
.gradle/
**/.gradle/
local.properties
**/local.properties

# Keep the wrapper itself (gradle/wrapper/gradle-wrapper.jar + .properties),
# ignore Gradle's own caches and transient outputs.

# =====================================================
# JetBrains Marketplace signing
# =====================================================
# Certificates & private keys should never be committed.
*.pem
*.p12
*.key
*.keystore

# =====================================================
# OS / editor cruft
# =====================================================
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
ehthumbs_vista.db
*.swp
*.swo
*~

# =====================================================
# Logs / temp
# =====================================================
*.log
logs/
*.tmp
*.bak
*.swp

# =====================================================
# Local backups (WSL-side .git stash after Windows git reinit)
# =====================================================
.git.wsl-bak/

# =====================================================
# IntelliJ Platform Gradle Plugin caches
# (downloaded IDE distributions and per-build scratch space)
# =====================================================
.intellijPlatform/

# =====================================================
# Kotlin compiler caches (Kotlin 2.x writes here at compile time;
# not source code, safe to ignore and re-generatable)
# =====================================================
.kotlin/

# =====================================================
# Commit-message draft files (used by `git commit -F .msg-*.txt`
# trick to avoid WSL->cmd quoting issues)
# =====================================================
.msg-*.txt

# =====================================================
# Per-developer Gradle overrides
# Anything that should not be committed (local proxy, Panda4 path,
# macports mirror, ...) goes in `~/.gradle/gradle.properties`,
# not in this repo. Adding gradle.local.properties here as a
# belt-and-braces in case someone tries to commit their local file
# with a different name.
# =====================================================
gradle.local.properties

# =====================================================
# Screenshot source files
# Only the final exported PNG/JPG should be committed to
# docs/screenshots/. Source files (Photoshop, Sketch, Figma
# exports, large TIFFs) are regeneratable and bloat the repo.
# =====================================================
docs/screenshots/*.psd
docs/screenshots/*.psb
docs/screenshots/*.sketch
docs/screenshots/*.fig
docs/screenshots/*.ai
docs/screenshots/*.tif
docs/screenshots/*.tiff
docs/screenshots/*.xcf

# =====================================================
# WSL DrvFS orphan files
# When the IntelliJ :test task writes to user.home=%TEMP% under WSL,
# files leak into the project root with absolute Windows paths
# (e.g. `C:\Users\ADMINI~1\AppData\Local\Temp\mac-linux-strategy-home*`).
# These appear as untracked files in `git status` and clutter `ls`.
# Field-tested 2026-07-01 — see skill reference wsl-test-temp-orphan-cleanup.md.
# =====================================================
# Anything that starts with a Windows drive letter and a colon
# (c:\, C:\, d:\, etc.) at the root of the repo.
/[A-Za-z]:\*
/[A-Za-z]:/**
